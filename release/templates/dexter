#!/bin/bash
set -eo pipefail

# Resolve symlinks to find the actual script location
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  # If SOURCE is relative, resolve it relative to the symlink's directory
  [[ "$SOURCE" != /* ]] && SOURCE="$SCRIPT_DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

UBER_JAR="$SCRIPT_DIR/{{uber-jar}}"

if [ ! -f "$UBER_JAR" ]; then
  echo "Error: dexter jar not found at $UBER_JAR" >&2
  exit 1
fi

AOT_TRAINING_DIR="$SCRIPT_DIR/aot-training"

# JDK 25+ AOT cache (Project Leyden): pre-loads and pre-links classes, and
# caches JIT method profiles for dramatically faster startup (~40%+).
# See JEP 483, JEP 514, JEP 515.
#
# The cache filename includes a hash of the JDK version, so switching JDKs
# simply bypasses the stale cache — no errors, no manual cleanup needed.

# Incorporate a hash of `java -version` into the cache filename so that
# a different JDK automatically gets its own (or no) cache file.
JDK_HASH=$(java -version 2>&1 | shasum -a 256 | cut -c1-12)
AOT_CACHE="$SCRIPT_DIR/dexter-${JDK_HASH}.aot"

AOT_FLAGS=()
if [ "${1:-}" = "--aot-train" ]; then
  JDK_MAJOR=$(java -version 2>&1 | head -1 | sed -E 's/.*"([0-9]+).*/\1/')
  if [ "${JDK_MAJOR:-0}" -lt 25 ]; then
    echo "Error: --aot-train requires JDK 25+ (current JDK: $JDK_MAJOR)" >&2
    exit 1
  fi

  if [ ! -d "$AOT_TRAINING_DIR" ]; then
    echo "Error: aot-training directory not found at $AOT_TRAINING_DIR" >&2
    exit 1
  fi

  echo "AOT training run: creating $AOT_CACHE ..." >&2
  rm -f "$SCRIPT_DIR"/dexter-*.aot
  java --enable-native-access=ALL-UNNAMED \
    -Ddexter.dry-run=true \
    -XX:AOTCacheOutput="$AOT_CACHE" \
    --class-path "$UBER_JAR" \
    clojure.main -m net.lewisship.dex.main \
    --file "$AOT_TRAINING_DIR"
  echo "AOT cache created successfully." >&2
  exit 0
fi

if [ -f "$AOT_CACHE" ]; then
  AOT_FLAGS=(-XX:AOTCache="$AOT_CACHE")
fi

exec java --enable-native-access=ALL-UNNAMED \
  "${AOT_FLAGS[@]}" \
  --class-path "$UBER_JAR" \
  clojure.main -m net.lewisship.dex.main "$@"
